// Prisma  schema - 数据模型定义
// 文档: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id    String  @id @default(uuid())  // 主键，自动生成 UUID
  name  String                         // 必填字段
  email String  @unique                // 唯一约束
  posts Post[]                         // 关联：一个用户有多篇文章
}

// 文章表
model Post {
  id        String   @id @default(uuid())
  title     String
  content   String?
  published Boolean  @default(false)   // 默认值
  createdAt DateTime @default(now())
  authorId  String                     // 外键
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  // 关联：多篇文章属于一个用户，删除用户时级联删除文章
}
